# flare-mcp environment configuration
# Copy this file to ".env" and adjust as needed.
# Every variable is OPTIONAL — the server runs against the public Flare RPC
# endpoints and Flare-hosted FDC services with no configuration at all.

# --- RPC endpoints -----------------------------------------------------------

# Flare Mainnet RPC (chainId 14). Defaults to the public endpoint below.
FLARE_RPC=https://flare-api.flare.network/ext/C/rpc

# Coston2 Testnet RPC (chainId 114). Defaults to the public endpoint below.
FLARE_RPC_TESTNET=https://coston2-api.flare.network/ext/C/rpc

# Songbird Canary-Network RPC (chainId 19). Defaults to the public endpoint.
# FLARE_RPC_SONGBIRD=https://songbird-api.flare.network/ext/C/rpc

# Coston Testnet RPC (chainId 16). Defaults to the public endpoint.
# FLARE_RPC_COSTON=https://coston-api.flare.network/ext/C/rpc

# --- FDC attestations --------------------------------------------------------

# OPTIONAL local signing key for fdc_request_attestation ONLY. When set, the
# tool submits attestation requests to FdcHub (small fee + gas). When unset,
# the tool returns the prepared request for your own signer and the server
# stays fully read-only. The key is used to sign locally and is never logged.
# FLARE_PRIVATE_KEY=

# API keys for the Flare-hosted verifier / Data Availability services.
# Default to the public key 00000000-0000-0000-0000-000000000000.
# FDC_VERIFIER_API_KEY=
# FLARE_DA_API_KEY=

# Override the Data Availability layer base URL (e.g. self-hosted).
# FLARE_DA_URL=

# --- x402 paywall (premium tools) ---------------------------------------------
# All OPTIONAL. When disabled (default), premium tools run free.

# Enable the x402 paywall on premium tools.
# X402_ENABLED=true

# Settlement network. mainnet additionally requires X402_ALLOW_MAINNET=true.
# X402_NETWORK=coston2

# Payee address that receives payments (required when enabled).
# X402_PAY_TO=

# EIP-3009 payment token override. Defaults: Coston2 test USDT0
# 0xce13911D4896200b543a61E4ae8E829E661Dd8EB, mainnet USD₮0
# 0xe7cd86e13AC4309349F30B3435a9d337750fC82D.
# X402_TOKEN_ADDRESS=

# Prices in whole-token units. Per-tool: X402_PRICE_<TOOL_NAME_UPPERCASED>.
# X402_PRICE_DEFAULT=0.001
# X402_PRICE_FASSETS_LIQUIDATION_SCANNER=0.005

# --- Optional data sources ---------------------------------------------------

# Indexer endpoint for get_ftso_providers. Must return a JSON array of
# providers, or an object shaped like { "providers": [ ... ] }. The tool
# appends ?network=mainnet|coston2 automatically.
# FLARE_PROVIDERS_API=

# Base URL of a Flare Data Availability (DA) Layer / indexer used by
# get_ftso_history. The tool requests <base>/api/v1/ftso/results?feed_id=...&limit=...
# FLARE_DA_LAYER_API=

# Optional fallback metrics API for get_fassets_status, consulted only if the
# on-chain read fails. The tool requests <base>/fassets/status.
# FLARE_METRICS_API=
